{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.4",
      "includeFiles": [
        "app/**",
        "bootstrap/**",
        "config/**",
        "database/**",
        "public/**",
        "resources/**",
        "routes/**",
        "vendor/**"
      ]
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/build/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}